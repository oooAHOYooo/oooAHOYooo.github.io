<?xml version='1.0' encoding='utf-8'?>
<widget id="io.cordova.ahoyApp" version="0.3.5" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">

    <!-- App Metadata -->
    <name>Ahoy</name>
    <description>Ahoy Indie Media is a hand-crafted indie media platform.</description>
    <author email="alex@ahoy.ooo" href="https://ahoy.ooo">Ahoy Indie Media Team</author>
    
    <!-- App Entry Point -->
    <content src="index.html" />
    
    <!-- Allow access to all domains -->
    <access origin="*" />
    
    <!-- Configure WKWebView (recommended for iOS) -->
    <feature name="CDVWKWebViewEngine">
        <param name="ios-package" value="CDVWKWebViewEngine" />
    </feature>
    <preference name="CordovaWebViewEngine" value="CDVWKWebViewEngine" />
    
    <!-- Enable Inline Media Playback -->
    <preference name="AllowInlineMediaPlayback" value="true" />
    <preference name="MediaTypesRequiringUserActionForPlayback" value="none" />
    
    <!-- Set Scheme and Hostname for Local Access -->
    <preference name="scheme" value="app" />
    <preference name="hostname" value="localhost" />
    
    <!-- Enable Cross-Origin Resource Sharing Policies -->
    <preference name="iosScheme" value="app" />
    <preference name="corsEnabled" value="true" />

    <!-- Electron Platform Settings -->
    <platform name="electron">
        <preference name="ElectronMainFile" value="cdv-electron-main.js" />
        <preference name="ElectronBackgroundColor" value="#FFFFFF" />
        <preference name="ElectronWindowWidth" value="1280" />
        <preference name="ElectronWindowHeight" value="720" />
    </platform>

    <!-- Android Platform -->
    <platform name="android">
        <icon src="resources/icons/android/mipmap-mdpi/ic_launcher.png" density="mdpi" />
        <icon src="resources/icons/android/mipmap-hdpi/ic_launcher.png" density="hdpi" />
        <icon src="resources/icons/android/mipmap-xhdpi/ic_launcher.png" density="xhdpi" />
        <icon src="resources/icons/android/mipmap-xxhdpi/ic_launcher.png" density="xxhdpi" />
        <icon src="resources/icons/android/mipmap-xxxhdpi/ic_launcher.png" density="xxxhdpi" />
        <splash src="resources/splash/android/drawable-mdpi/splash.png" density="mdpi" />
        <splash src="resources/splash/android/drawable-hdpi/splash.png" density="hdpi" />
        <splash src="resources/splash/android/drawable-xhdpi/splash.png" density="xhdpi" />
        <splash src="resources/splash/android/drawable-xxhdpi/splash.png" density="xxhdpi" />
        <splash src="resources/splash/android/drawable-xxxhdpi/splash.png" density="xxxhdpi" />
    </platform>

    <!-- iOS Platform -->
    <platform name="ios">
        <icon src="resources/icons/ios/Icon-App-20x20@1x.png" width="20" height="20" />
        <icon src="resources/icons/ios/Icon-App-20x20@2x.png" width="40" height="40" />
        <icon src="resources/icons/ios/Icon-App-20x20@3x.png" width="60" height="60" />
        <icon src="resources/icons/ios/Icon-App-29x29@1x.png" width="29" height="29" />
        <icon src="resources/icons/ios/Icon-App-29x29@2x.png" width="58" height="58" />
        <icon src="resources/icons/ios/Icon-App-29x29@3x.png" width="87" height="87" />
        <icon src="resources/icons/ios/Icon-App-40x40@1x.png" width="40" height="40" />
        <icon src="resources/icons/ios/Icon-App-40x40@2x.png" width="80" height="80" />
        <icon src="resources/icons/ios/Icon-App-40x40@3x.png" width="120" height="120" />
        <icon src="resources/icons/ios/Icon-App-60x60@2x.png" width="120" height="120" />
        <icon src="resources/icons/ios/Icon-App-60x60@3x.png" width="180" height="180" />
        <icon src="resources/icons/ios/Icon-App-76x76@1x.png" width="76" height="76" />
        <icon src="resources/icons/ios/Icon-App-76x76@2x.png" width="152" height="152" />
        <icon src="resources/icons/ios/Icon-App-83.5x83.5@2x.png" width="167" height="167" />
        <icon src="resources/icons/ios/iTunesArtwork@1x.png" width="512" height="512" />
        <icon src="resources/icons/ios/iTunesArtwork@2x.png" width="1024" height="1024" />
        <icon src="resources/icons/ios/iTunesArtwork@3x.png" width="1536" height="1536" />
    </platform>

</widget>
