{
  "functions": {
    "api/track-redirect.js": {
      "maxDuration": 10
    },
    "api/track-redirect-resend.js": {
      "maxDuration": 10
    }
  },
  "redirects": [
    {
      "source": "/newhaven",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/newhaven/",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/support",
      "destination": "/support/index.html"
    },
    {
      "source": "/support/",
      "destination": "/support/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy/index.html"
    },
    {
      "source": "/privacy/",
      "destination": "/privacy/index.html"
    }
  ]
}
